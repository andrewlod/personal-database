# Copy this file to .env and fill in your API keys.
# The .env file is loaded automatically at startup.

# OpenRouter API key (required for LLM-powered answers)
# Get one at https://openrouter.ai/
OPENROUTER_API_KEY=

# Weaviate API key (only needed for cloud-hosted Weaviate)
# Leave empty for local Docker deployment
WEAVIATE_API_KEY=
